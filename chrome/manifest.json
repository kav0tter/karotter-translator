{
  "manifest_version": 3,
  "name": "Karotter Translator",
  "version": "1.0.0",
  "description": "karotter.comの投稿をLLMで翻訳するChrome拡張",
  "permissions": ["storage", "sidePanel"],
  "host_permissions": [
    "https://karotter.com/*",
    "https://karotter.jp/*",
    "https://karotter.karon.jp/*",
    "https://*/*"
  ],
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://karotter.com/*",
        "https://karotter.jp/*",
        "https://karotter.karon.jp/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
